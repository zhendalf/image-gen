{
  "name": "images-mcp",
  "version": "1.2.2",
  "description": "MCP server for AI image generation using OpenAI and Google Gemini",
  "type": "module",
  "main": "mcp.ts",
  "bin": {
    "images-mcp": "cli.ts"
  },
  "files": [
    "cli.ts",
    "core.ts",
    "mcp.ts",
    "schemas.ts"
  ],
  "scripts": {
    "start": "bun run mcp.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "ci:check": "bun run test && bun run typecheck"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "image-generation",
    "openai",
    "gemini",
    "dall-e",
    "gpt-image"
  ],
  "author": "ebeloded",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebeloded/images-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ebeloded/images-mcp/issues"
  },
  "homepage": "https://github.com/ebeloded/images-mcp#readme",
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "clipanion": "^4.0.0-rc.4",
    "openai": "^6.14.0",
    "zod": "^4.2.1"
  }
}
